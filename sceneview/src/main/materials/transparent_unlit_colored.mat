material {
    "name" : "Transparent Unlit Colored",

    "parameters" : [
        {
           "type" : "float4",
           "name" : "color"
        }
    ],
    "requires" : [
        "position"
    ],
    "shadingModel" : "unlit",
    "blending" : "transparent",
    "doubleSided" : true
}
fragment {
    void material(inout MaterialInputs material) {
        prepareMaterial(material);
        material.baseColor = materialParams.color;
    }
}
