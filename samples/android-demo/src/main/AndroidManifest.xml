<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- AR is optional — app works without it -->
    <uses-feature
        android:name="android.hardware.camera.ar"
        android:required="false" />

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required by the Streetscape Geometry / Geospatial demos. ARCore throws
         FineLocationPermissionNotGrantedException if Geospatial mode is enabled
         without this permission — the demo composable requests it at runtime
         before configuring the session. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Required for PermissionImpliesUnsupportedChromeOsHardware lint rule -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SceneViewDemo">

        <!-- ARCore metadata — optional -->
        <meta-data
            android:name="com.google.ar.core"
            android:value="optional" />

        <!-- ARCore Cloud API key — required for Geospatial, Streetscape Geometry,
             and Cloud Anchors. Injected from local.properties (or the ARCORE_API_KEY
             env var) at build time via the manifestPlaceholders in build.gradle.
             Empty by default — when blank, the demo's runtime check disables the
             features that need it and shows a clear status message instead of
             crashing. See arsceneview/STREETSCAPE_SETUP.md. -->
        <meta-data
            android:name="com.google.android.ar.API_KEY"
            android:value="${arcoreApiKey}" />

        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboard|keyboardHidden|uiMode"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Deep-link entry: scan a QR code on sceneview.github.io / README /
                docs and land directly on the matching demo screen.
                See website-static/.well-known/README.md for the verification
                state and follow-up steps.
            -->

            <!-- Custom scheme — works on every install, no verification needed. -->
            <intent-filter android:label="Open in SceneView Demo">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="sceneview" android:host="demo" />
            </intent-filter>

            <!--
                Verified App-Link over HTTPS — pairs with
                `website-static/.well-known/assetlinks.json`. autoVerify is
                kept ON so the system fetches the manifest at install time;
                until the Play App Signing SHA-256 is added to assetlinks.json
                (TODO in that file), verification will silently fail for Play
                Store installs and the URL falls back to the disambiguation
                picker. Local debug installs (signed with the upload key)
                already verify successfully.
            -->
            <intent-filter android:label="Open in SceneView Demo" android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="sceneview.github.io" android:pathPrefix="/open" />
            </intent-filter>
        </activity>
    </application>
</manifest>
